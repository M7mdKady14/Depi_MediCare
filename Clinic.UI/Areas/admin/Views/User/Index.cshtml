@model List<UserInfoDTO>

@section Styles {
    <style>
        .table th,
        .table td {
            text-align: center;
            vertical-align: middle;
        }
    </style>
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <div>
            <h5 class="mb-0 fw-bold">Users</h5>
            <small class="text-muted">Manage system users</small>
        </div>

        <a asp-action="Register" class="btn btn-primary">
            <i class="fa-solid fa-plus"></i>
            Add User
        </a>
    </div>

    <div class="card-body">
        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>User Name</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Phone Number</th>
                        <th>Role</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @{
                        int counter = 1;
                    }

                    @foreach (var user in Model)
                    {
                        <tr>

                            <td>@counter</td>

                            <td>
                                @user.UserName
                            </td>

                            <td>@user.FirstName @user.LastName</td>

                            <td>@((string.IsNullOrEmpty(user.Email)) ? "No Email Found" : user.Email)</td>

                            <td>@user.PhoneNumber</td>

                            <td>
                                <span class="badge bg-info">
                                    @user.Role
                                </span>
                            </td>

                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Details" asp-route-userId="@user.Id" class="action-btn" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>

                                    <a asp-action="UpdateUser" asp-route-userId="@user.Id" class="action-btn" title="Edit Staff">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                    @if (user.Role != "Doctor") 
                                    {
                                        <a asp-action="ChangeUserRole" asp-route-userId="@user.Id" class="action-btn" title="Privileges">
                                            <i class="fas fa-user-shield"></i>
                                        </a>
                                    }
                                    <a asp-action="ResetPassword" asp-route-userId="@user.Id" class="action-btn" title="Security Reset">
                                        <i class="fas fa-key"></i>
                                    </a>

                                    <form asp-action="DeleteUser"
                                          asp-route-userId="@user.Id"
                                          method="post"
                                          onsubmit="return confirm('Are you sure?');"
                                          style="display:inline;">
                                        <button type="submit" class="action-btn btn-delete" title="Remove Access">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>

                        </tr>

                        counter++;
                    }

                </tbody>

            </table>

        </div>
    </div>
</div>