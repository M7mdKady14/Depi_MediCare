@model MedicalRadiologyDTO

@{
    ViewData["PageTitle"] = "Medical Radiology Management";
    ViewData["PageSubtitle"] = "Add New Medical Radiology to Patient Medical Record";

    string fileExt = string.IsNullOrEmpty(Model.File) ? "" : System.IO.Path.GetExtension(Model.File).ToLowerInvariant();
    bool isPdf = fileExt == ".pdf";
    bool hasFile = !string.IsNullOrEmpty(Model.File);
}

@section Styles {
    <link rel="stylesheet" href="~/doctor/css/test/add.css" />
}

<div class="container-fluid">
    <div class="admin-card">
        <div class="card-header-custom">
            <h3><i class="fas fa-user-plus me-2"></i> Add Medical Radiology </h3>
        </div>
        <div class="card-body-custom">
            <form method="post" asp-action="Save" enctype="multipart/form-data">
                <div class="row">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="MedicalRecordId" />
                    <input type="hidden" name="OldFile" value="@Model.File" />
                    <div class="col-md-12">
                        <div class="input-group-custom">
                            <label class="form-label-custom">File</label>

                            <div id="tbImgSrc"
                                 class="mb-3 position-relative d-flex align-items-center justify-content-center"
                                 style="width:250px; height:250px; border-radius:2px; border-style:solid; cursor:pointer; overflow:hidden;"
                                 onclick="document.getElementById('imageInput').click()">

                                <img src="~/Uploads/MedicalRadiologies/@Model.File"
                                     alt=""
                                     class="img-fluid image-preview position-absolute @(isPdf || !hasFile ? "d-none" : "")"
                                     id="tbImgName"
                                     style="max-width:100%; max-height:100%;">

                                <div id="pdfPreview"
                                     class="d-flex flex-column align-items-center justify-content-center text-muted position-absolute @(isPdf ? "" : "d-none")">
                                    <i class="fas fa-file-pdf" style="font-size: 3.5rem; color:#d9534f;"></i>
                                    <span class="small mt-2 text-truncate" style="max-width:220px;">@Model.File</span>
                                </div>

                                <span id="plusIcon"
                                      class="position-absolute text-muted @(hasFile ? "d-none" : "")"
                                      style="font-size: 3rem; pointer-events: none; user-select: none;">+</span>
                            </div>

                            <!-- Hidden file input -->
                            <input id="imageInput"
                                   class="d-none"
                                   type="file"
                                   name="file"
                                   value="~/Uploads/MedicalRadiologies/@Model.File"
                                   onchange="upload.UploadDefaultImg(event)"
                                   accept=".jpg, .jpeg, .png, .pdf">

                            <div>
                                <p>@(Model.File == null ? "No Files Yet" : Model.File.ToLower())</p>
                            </div>

                            <button type="button"
                                    class="btn btn-danger mt-2"
                                    onclick="deleteFile()">
                                Delete File
                            </button>

                            <span asp-validation-for="File" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="input-group-custom">
                            <label class="form-label-custom">Description</label>
                            <textarea asp-for="Description" class="form-control-custom" placeholder="Enter Test Description">
                            </textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="text-end">
                    <a asp-action="Index" class="btn btn-back-list me-4">
                        <i class="fas fa-arrow-left me-2"></i>
                        Back To List
                    </a>

                    <button type="submit" class="btn btn-create-user">
                        <i class="fas fa-check-circle me-2"></i>
                        Add Medical Radiology
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        var CourseMediaImgName = "";
        var CourseMediaImgBase64 = "";
        var upload = {
            UploadDefaultImg: function (e) {
                const file = e.target.files[0];
                if (!file) return;

                const isPdfFile = file.type === "application/pdf" || file.name.toLowerCase().endsWith(".pdf");
                const reader = new FileReader();

                reader.onloadend = () => {
                    CourseMediaImgName = file.name;
                    CourseMediaImgBase64 = reader.result.slice(reader.result.indexOf('base64,') + 7);

                    $("#plusIcon").addClass("d-none");

                    if (isPdfFile) {
                        // Show PDF icon + filename, hide image preview
                        $("#tbImgName").addClass("d-none");
                        $("#pdfPreview").removeClass("d-none");
                        $("#pdfPreview .small").text(file.name);
                    } else {
                        // Show image preview, hide PDF icon
                        $("#pdfPreview").addClass("d-none");
                        $("#tbImgName").attr("src", reader.result).removeClass("d-none");
                    }
                };

                reader.readAsDataURL(file);
            }
        };

        // Simulate sidebar toggle for demonstration
        $(".sidebar-toggle").click(function () {
            $("body").toggleClass("sidebar-open");
        });
    </script>
}
