@model PageResult<DoctorInfoDTO>

@section Styles {
    <link href="~/admin/css/doctor/index.css" rel="stylesheet" />
}

<div class="page-wrapper">

    <!-- SEARCH BOX -->
    <div class="card search-card">
        <form method="get"
              asp-area="admin"
              asp-controller="Doctor"
              asp-action="Index"
              class="search-form">

            <input type="text"
                   name="Name"
                   value="@Context.Request.Query["Name"]"
                   placeholder="Doctor name"
                   class="form-control" />

            <input type="text"
                   name="PhoneNumber"
                   value="@Context.Request.Query["PhoneNumber"]"
                   placeholder="Phone"
                   class="form-control" />

            @{
                var specializations = (List<SpecializationDTO>)ViewBag.lstSpecializations;
            }

            <select name="SpecializationId"
                    class="form-select">
                <option value="">Select Specialization</option>

                @foreach (var item in specializations)
                {
                    <option value="@item.Id"
                            selected="@(Context.Request.Query["SpecializationId"] == item.Id.ToString())">
                        @item.EName
                    </option>
                }
            </select>

            <div class="search-actions">
                <button type="submit" class="btn btn-search">Search</button>

                <a asp-area="admin"
                   asp-controller="Doctor"
                   asp-action="Index"
                   class="btn btn-reset">
                    Reset
                </a>
            </div>

        </form>
    </div>

    <!-- TABLE CARD -->
    <div class="card table-card">

        <div class="card-header">
            <span>Doctors</span>

            <a class="btn btn-add"
               asp-area="admin"
               asp-controller="User"
               asp-action="Register">
                + Add Doctor
            </a>
        </div>

        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Specialization</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var doctor in Model.Items)
                    {
                        <tr>
                            <td class="name">@doctor.Name</td>
                            <td>@doctor.SpecializationName</td>
                            <td>
                                <div class="actions">
                                    <a class="btn btn-info"
                                       asp-area="admin"
                                       asp-controller="Doctor"
                                       asp-action="Details"
                                       asp-route-Id="@doctor.Id">Details</a>

                                    <a class="btn btn-edit"
                                       asp-area="admin"
                                       asp-controller="Doctor"
                                       asp-action="Edit"
                                       asp-route-Id="@doctor.Id">Edit</a>

                                    <a class="btn btn-delete"
                                       asp-area="admin"
                                       asp-controller="Doctor"
                                       asp-action="Delete"
                                       asp-route-Id="@doctor.Id">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        @{
            var search = Context.Request.Query;

            int windowSize = 2;
            int current = Model.PageNumber;
            int total = Model.TotalPages;
        }

        <div class="pg-row">
            <span class="pg-info">
                Page @current of @total — @Model.TotalCount doctors
            </span>

            <div class="pg-btns">

                <!-- Prev -->
                <a asp-action="Index"
                   asp-route-pageNumber="@(current - 1)"
                   asp-route-Name="@search["Name"]"
                   asp-route-PhoneNumber="@search["PhoneNumber"]"
                   asp-route-SpecializationId="@search["SpecializationId"]"
                   class="pg-btn @(!Model.HasPrev ? "disabled" : "")">
                    Prev
                </a>

                @{
                    int rangeStart = Math.Max(2, current - windowSize);
                    int rangeEnd = Math.Min(total - 1, current + windowSize);
                }

                <!-- First -->
                <a asp-action="Index"
                   asp-route-pageNumber="1"
                   asp-route-Name="@search["Name"]"
                   asp-route-PhoneNumber="@search["PhoneNumber"]"
                   asp-route-SpecializationId="@search["SpecializationId"]"
                   class="pg-btn @(current == 1 ? "active" : "")">
                    1
                </a>

                @if (rangeStart > 2)
                {
                    <span class="pg-ellipsis">…</span>
                }

                <!-- Middle -->
                @for (int i = rangeStart; i <= rangeEnd; i++)
                {
                    <a asp-action="Index"
                       asp-route-pageNumber="@i"
                       asp-route-Name="@search["Name"]"
                       asp-route-PhoneNumber="@search["PhoneNumber"]"
                       asp-route-SpecializationId="@search["SpecializationId"]"
                       class="pg-btn @(i == current ? "active" : "")">
                        @i
                    </a>
                }

                @if (rangeEnd < total - 1)
                {
                    <span class="pg-ellipsis">…</span>
                }

                <!-- Last -->
                @if (total > 1)
                {
                    <a asp-action="Index"
                       asp-route-pageNumber="@total"
                       asp-route-Name="@search["Name"]"
                       asp-route-PhoneNumber="@search["PhoneNumber"]"
                       asp-route-SpecializationId="@search["SpecializationId"]"
                       class="pg-btn @(current == total ? "active" : "")">
                        @total
                    </a>
                }

                <!-- Next -->
                <a asp-action="Index"
                   asp-route-pageNumber="@(current + 1)"
                   asp-route-Name="@search["Name"]"
                   asp-route-PhoneNumber="@search["PhoneNumber"]"
                   asp-route-SpecializationId="@search["SpecializationId"]"
                   class="pg-btn @(!Model.HasNext ? "disabled" : "")">
                    Next
                </a>

            </div>
        </div>

    </div>
</div>