@model ResetPasswordDTO

@{
    ViewData["PageTitle"] = "Security Management";
    ViewData["PageSubtitle"] = "Issue new secure access credentials for this account";
}

@section Styles {
    <link rel="stylesheet" href="~/admin/css/User/resetpassword.css" />
}


<div class="security-card">
    <div class="security-badge">
        <i class="fas fa-shield-alt"></i>
    </div>

    <div class="card-header-security">
        <h3>Reset Password</h3>
    </div>

    <p class="security-hint">Please enter a new high-security password for this user account.</p>

    <div class="form-container">
        <form method="post" asp-action="ResetPassword">
            <input type="hidden" asp-for="UserId" />

            <div class="input-wrapper">
                <i class="fas fa-lock"></i>
                <input asp-for="Password" type="password" class="form-control-security" placeholder="New Secure Password" />
                <span asp-validation-for="Password" class="text-danger d-block mt-1" style="font-size: 0.75rem;"></span>
            </div>

            <div class="input-wrapper">
                <i class="fas fa-check-double"></i>
                <input asp-for="ConfirmPassword" type="password" class="form-control-security" placeholder="Confirm New Password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger d-block mt-1" style="font-size: 0.75rem;"></span>
            </div>

            <button type="submit" class="btn-reset-confirm">
                Update Credentials
            </button>

            <a asp-action="Index" class="cancel-link">Return to Staff Directory</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}