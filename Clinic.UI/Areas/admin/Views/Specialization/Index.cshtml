@model List<SpecializationDTO>

@section Styles
{
    <link href="~/admin/css/specialization/index.css" rel="stylesheet" />
}

<div class="page-wrapper">

    <div class="card spec-card shadow-sm">

        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Specialization</span>

            <a class="btn btn-light btn-sm"
               asp-area="admin"
               asp-controller="Specialization"
               asp-action="Edit">
                + Add New Specialization
            </a>
        </div>

        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>English Name</th>
                        <th>Arabic Name</th>
                        <th style="width: 160px;">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="specialization-en">@item.EName</td>

                            <td class="specialization-ar">
                                @(string.IsNullOrEmpty(item.AName) ? "-" : item.AName)
                            </td>

                            <td>
                                <div class="d-flex gap-2">
                                    <a class="btn btn-outline-secondary btn-sm"
                                       asp-area="admin"
                                       asp-controller="Specialization"
                                       asp-action="Edit"
                                       asp-route-Id="@item.Id">
                                        Edit
                                    </a>

                                    <a class="btn btn-outline-danger btn-sm"
                                       asp-area="admin"
                                       asp-controller="Specialization"
                                       asp-action="Delete"
                                       asp-route-Id="@item.Id">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}