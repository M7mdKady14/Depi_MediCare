@model ScheduleDTO

@{
    ViewData["PageTitle"] = "Doctor Schedules Management";
    ViewData["PageSubtitle"] = "Update Schedule";
}

@section Styles {
    <link rel="stylesheet" href="~/admin/css/schedule/edit.css" />
}

<div class="container-fluid">
    <div class="admin-card">
        <div class="card-header-custom">
            <h3>
                <i class="fa-solid fa-calendar-days"></i>
                @(Model.Id == Guid.Empty ? "Create Schedule" : "Edit Schedule")
            </h3>
        </div>
        <div class="card-body-custom">
            <form method="post" asp-action="Save">
                <div class="row">
                    <input type="hidden" asp-for="Id" />
                    <div class="col-md-12">
                        <div class="input-group-custom">
                            <label class="form-label-custom">Day</label>
                            <select asp-for="Day" asp-items="ViewBag.lstDays" class="form-control-custom">
                                <option disabled selected hidden>Select Day</option>
                            </select>
                            <span asp-validation-for="Day" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="input-group-custom">
                            <label class="form-label-custom">Start Time</label>
                            <input type="time" asp-for="StartTime" class="form-control-custom" placeholder="Enter Start Time" />
                            <span asp-validation-for="StartTime" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="input-group-custom">
                            <label class="form-label-custom">End Time</label>
                            <input type="time" asp-for="EndTime" class="form-control-custom" placeholder="Enter End Time" />
                            <span asp-validation-for="EndTime" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="text-center">
                    <a asp-action="Index" class="btn btn-back-list me-4">
                        <i class="fas fa-arrow-left me-2"></i>
                        Back To List
                    </a>

                    <button type="submit" class="btn btn-create-user">
                        <i class="fas fa-check-circle me-2"></i>
                        @(Model.Id == Guid.Empty ? "Create Schedule" : "Edit Schedule")
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}