@model UpdateUserDTO

@{
    ViewData["PageTitle"] = "User Management";
    ViewData["PageSubtitle"] = "Update staff member";
}

@section Styles {
    <link rel="stylesheet" href="~/admin/css/User/updateuser.css" />
}

<div class="container-fluid">
    <div class="admin-card">
        <div class="card-header-custom">
            <h3><i class="fas fa-user-plus me-2"></i> Update Staff Member</h3>
        </div>
        <div class="card-body-custom">
            <form method="post" asp-action="UpdateUser">
                <input asp-for="UserId" type="hidden"/>

                <div class="row">
                    <div class="col-md-6">
                        <div class="input-group-custom">
                            <label class="form-label-custom">Username</label>
                            <input asp-for="UserName" class="form-control-custom" placeholder="e.g. john_dream" />
                            <span asp-validation-for="UserName" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="input-group-custom">
                            <label class="form-label-custom">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control-custom" placeholder="+1 234..." />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="input-group-custom">
                            <label class="form-label-custom">First Name</label>
                            <input asp-for="FirstName" class="form-control-custom" placeholder="First Name" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="input-group-custom">
                            <label class="form-label-custom">Last Name</label>
                            <input asp-for="LastName" class="form-control-custom" placeholder="Last Name" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="text-end">
                    <a asp-action="Index" class="btn btn-back-list me-4">
                        <i class="fas fa-arrow-left me-2"></i>
                        Back To List
                    </a>

                    <button type="submit" class="btn btn-create-user">
                        <i class="fas fa-check-circle me-2"></i>
                        Update User
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}