@model PageResult<PatientInfoDTO>

@section Styles {
    <link href="~/css/doctor/index.css" rel="stylesheet" />
}

<div class="page-wrapper">

    <!-- SEARCH BOX -->
    <div class="card search-card">
        <form method="get"
              asp-controller="Patient"
              asp-action="Index"
              class="search-form">

            <input type="text"
                   name="Name"
                   value="@Context.Request.Query["Name"]"
                   placeholder="Patient name"
                   class="form-control" />

            <input type="text"
                   name="PhoneNumber"
                   value="@Context.Request.Query["PhoneNumber"]"
                   placeholder="Phone"
                   class="form-control" />

            <input type="text"
                   name="NationalNumber"
                   value="@Context.Request.Query["NationalNumber"]"
                   placeholder="National Number"
                   class="form-control" />

            <div class="search-actions">
                <button type="submit" class="btn btn-search">Search</button>

                <a asp-controller="Patient"
                   asp-action="Index"
                   class="btn btn-reset">
                    Reset
                </a>
            </div>

        </form>
    </div>

    <!-- TABLE CARD -->
    <div class="card table-card">

        <div class="card-header">
            <span>Patients</span>

            <a class="btn btn-add"
               asp-controller="Patient"
               asp-action="Add">
                + Add Patient
            </a>
        </div>

        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>PhoneNumber</th>
                        <th>National Number</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var patient in Model.Items)
                    {
                        <tr>
                            <td class="name">@patient.FirstName @patient.MiddleName @patient.LastName</td>
                            <td>@patient.PhoneNumber</td>
                            <td>@patient.NationalNumber</td>
                            <td>
                                <div class="actions">
                                    <a class="btn btn-info"
                                       asp-controller="Patient"
                                       asp-action="Details"
                                       asp-route-Id="@patient.Id">Details</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        @{
            var search = Context.Request.Query;

            int windowSize = 2;
            int current = Model.PageNumber;
            int total = Model.TotalPages;
        }

        <div class="pg-row">
            <span class="pg-info">
                Page @current of @total — @Model.TotalCount patients
            </span>

            <div class="pg-btns">

                <!-- Prev -->
                <a asp-action="Index"
                   asp-route-pageNumber="@(current - 1)"
                   asp-route-Name="@search["Name"]"
                   asp-route-PhoneNumber="@search["PhoneNumber"]"
                   asp-route-NationalNumber="@search["NationalNumber"]"
                   class="pg-btn @(!Model.HasPrev ? "disabled" : "")">
                    Prev
                </a>

                @{
                    int rangeStart = Math.Max(2, current - windowSize);
                    int rangeEnd = Math.Min(total - 1, current + windowSize);
                }

                <!-- First -->
                <a asp-action="Index"
                   asp-route-pageNumber="1"
                   asp-route-Name="@search["Name"]"
                   asp-route-PhoneNumber="@search["PhoneNumber"]"
                   asp-route-NationalNumber="@search["NationalNumber"]"
                   class="pg-btn @(current == 1 ? "active" : "")">
                    1
                </a>

                @if (rangeStart > 2)
                {
                    <span class="pg-ellipsis">…</span>
                }

                <!-- Middle -->
                @for (int i = rangeStart; i <= rangeEnd; i++)
                {
                    <a asp-action="Index"
                       asp-route-pageNumber="@i"
                       asp-route-Name="@search["Name"]"
                       asp-route-PhoneNumber="@search["PhoneNumber"]"
                       asp-route-NationalNumber="@search["NationalNumber"]"
                       class="pg-btn @(i == current ? "active" : "")">
                        @i
                    </a>
                }

                @if (rangeEnd < total - 1)
                {
                    <span class="pg-ellipsis">…</span>
                }

                <!-- Last -->
                @if (total > 1)
                {
                    <a asp-action="Index"
                       asp-route-pageNumber="@total"
                       asp-route-Name="@search["Name"]"
                       asp-route-PhoneNumber="@search["PhoneNumber"]"
                       asp-route-NationalNumber="@search["NationalNumber"]"
                       class="pg-btn @(current == total ? "active" : "")">
                        @total
                    </a>
                }

                <!-- Next -->
                <a asp-action="Index"
                   asp-route-pageNumber="@(current + 1)"
                   asp-route-Name="@search["Name"]"
                   asp-route-PhoneNumber="@search["PhoneNumber"]"
                   asp-route-NationalNumber="@search["NationalNumber"]"
                   class="pg-btn @(!Model.HasNext ? "disabled" : "")">
                    Next
                </a>

            </div>
        </div>

    </div>
</div>