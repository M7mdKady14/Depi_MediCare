@model AppointmentInfoDTO

@section Styles
{
    <link href="~/doctor/css/appointment/details.css" rel="stylesheet" />
}

@{
    ViewData["Title"] = "Appointment Details";
    string badgeClass;
    string badgeIcon;

    switch (Model.AppointmentStatus)
    {
        case Clinic.Core.Enums.AppointmentStatus.Waiting:
            badgeClass = "dmc-badge-waiting"; badgeIcon = "fa-clock"; break;
        case Clinic.Core.Enums.AppointmentStatus.Created:
            badgeClass = "dmc-badge-confirmed"; badgeIcon = "fa-check"; break;
        case Clinic.Core.Enums.AppointmentStatus.InProgress:
            badgeClass = "dmc-badge-inroom"; badgeIcon = "fa-door-open"; break;
        case Clinic.Core.Enums.AppointmentStatus.Completed:
            badgeClass = "dmc-badge-done"; badgeIcon = "fa-circle-check"; break;
        case Clinic.Core.Enums.AppointmentStatus.Canceled:
            badgeClass = "dmc-badge-cancelled"; badgeIcon = "fa-circle-xmark"; break;
        default:
            badgeClass = "dmc-badge-new"; badgeIcon = "fa-circle-info"; break;
    }
}

<div class="dmc-page-grid">

    <!-- ════════════ LEFT: Appointment details ════════════ -->
    <div class="dmc-panel">
        <div class="dmc-panel-header">
            <div class="dmc-panel-title">Appointment Details</div>
            <div class="dmc-panel-actions">
                <span class="dmc-badge @badgeClass">
                    <i class="fa-solid @badgeIcon"></i> @Model.AppointmentStatus
                </span>
            </div>
        </div>

        <div class="dmc-panel-body" style="padding:1.25rem;">

            <!-- Patient & Doctor summary row -->
            <div class="dmc-stats" style="grid-template-columns: repeat(2, 1fr); margin-bottom:1.5rem;">
                <div class="dmc-stat-card">
                    <div class="dmc-stat-icon teal">
                        <i class="fa-solid fa-user"></i>
                    </div>
                    <div>
                        <div class="dmc-stat-value" style="font-size:1rem;">@Model.PatientName</div>
                        <div class="dmc-stat-label">Patient</div>
                    </div>
                </div>
                <div class="dmc-stat-card">
                    <div class="dmc-stat-icon blue">
                        <i class="fa-solid fa-user-doctor"></i>
                    </div>
                    <div>
                        <div class="dmc-stat-value" style="font-size:1rem;">Dr. @Model.DoctorName</div>
                        <div class="dmc-stat-label">Doctor</div>
                    </div>
                </div>
            </div>

            <!-- Detail rows -->
            <table class="dmc-table">
                <tbody>
                    <tr>
                        <td style="width:220px; color:#6b8c85; font-weight:500;">
                            <i class="fa-solid fa-stethoscope" style="width:18px; color:var(--dmc-teal);"></i>
                            Appointment Type
                        </td>
                        <td>@Model.AppointmentTypeName</td>
                    </tr>
                    <tr>
                        <td style="color:#6b8c85; font-weight:500;">
                            <i class="fa-regular fa-calendar" style="width:18px; color:var(--dmc-teal);"></i>
                            Appointment Date
                        </td>
                        <td>@Model.AppointmentDate.ToString("dddd, MMM dd yyyy")</td>
                    </tr>
                    <tr>
                        <td style="color:#6b8c85; font-weight:500;">
                            <i class="fa-solid fa-calendar-day" style="width:18px; color:var(--dmc-teal);"></i>
                            Schedule Day
                        </td>
                        <td>@Model.Day</td>
                    </tr>
                    <tr>
                        <td style="color:#6b8c85; font-weight:500;">
                            <i class="fa-regular fa-clock" style="width:18px; color:var(--dmc-teal);"></i>
                            Time Slot
                        </td>
                        <td>@DateTime.Today.Add(Model.StartTime).ToString(@"hh\:mm") &ndash; @DateTime.Today.Add(Model.EndTime).ToString(@"hh\:mm")</td>
                    </tr>
                </tbody>
            </table>

        </div>
    </div>

    <!-- ════════════ RIGHT: Quick actions / related links ════════════ -->
    <div class="dmc-panel">
        <div class="dmc-panel-header">
            <div class="dmc-panel-title">Quick Actions</div>
        </div>
        <div class="dmc-panel-body" style="padding:1rem 1.25rem; display:flex; flex-direction:column; gap:10px;">

            @if (Model.AppointmentStatus == AppointmentStatus.InProgress || Model.AppointmentStatus == AppointmentStatus.Completed)
            {
                <a class="btn btn-info d-flex align-items-center justify-content-center"
                   asp-area="doctor"
                   asp-controller="Prescription"
                   asp-action="Details"
                   asp-route-appointmentId="@Model.Id">
                    <i class="fa-solid fa-prescription me-2"></i>
                    Prescription
                </a>
            }

            <a class="dmc-btn-primary" style="justify-content:center; background:#185fa5;"
               asp-area="doctor" asp-controller="Patient" asp-action="Details" asp-route-Id="@Model.PatientId">
                <i class="fa-solid fa-user"></i> View Patient Profile
            </a>

            <hr style="border-color:var(--dmc-border); margin:6px 0;" />

            <a class="dmc-action-link" asp-area="doctor" asp-controller="Appointment" asp-action="Index">
                <i class="fa-solid fa-arrow-left"></i> Back to All Appointments
            </a>
        </div>
    </div>
</div>
